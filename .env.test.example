# Copy this file to .env.test.local and fill in the secrets.
# .env.test.local is gitignored.

# Base URL for Playwright to hit.
# Local dev: http://localhost:3000
# Staging:   https://staging.kidvo.eu
PLAYWRIGHT_BASE_URL=http://localhost:3000

# Supabase project the tests run against — MUST be kidvo-staging, never
# kidvo-prod. The tests create and delete real users via the admin API.
# Find the URL in: Supabase dashboard → kidvo-staging → Project Settings
# → API → "Project URL".
SUPABASE_URL=https://<staging-project-ref>.supabase.co

# Service-role key for kidvo-staging (NOT prod). Same screen as above,
# under "Project API keys" → service_role → Reveal.
# This key bypasses RLS — never paste it anywhere except .env.test.local.
SUPABASE_SERVICE_ROLE_KEY=
