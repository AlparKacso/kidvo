# Copy this file to .env.test.local and fill in the secrets.
# .env.test.local is gitignored.

# Base URL for Playwright to hit.
# Local dev: http://localhost:3000
# Staging:   https://staging.kidvo.eu
PLAYWRIGHT_BASE_URL=http://localhost:3000

# Supabase project the tests run against (usually staging, never prod).
SUPABASE_URL=https://ztkkigwqjnzlitksbngg.supabase.co

# Service-role key — required so tests can pre-seed confirmed users via
# admin.createUser({ email_confirm: true }) and clean them up afterwards.
# Find it in Supabase dashboard → Project Settings → API → service_role.
SUPABASE_SERVICE_ROLE_KEY=
